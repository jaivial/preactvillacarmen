APP_ENV=local
PORT=8080
STATIC_DIR=../frontend/dist

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=villacarmen
DB_PASSWORD=villacarmen
DB_NAME=villacarmen

# Dev only (Vite)
CORS_ALLOW_ORIGINS=http://localhost:5173
VITE_BUNNY_PULL_BASE_URL=https://villacarmenmedia.b-cdn.net

# BunnyCDN (wine photos)
BUNNY_PULL_BASE_URL=https://villacarmenmedia.b-cdn.net
BUNNY_STORAGE_ZONE=villacarmen
BUNNY_STORAGE_ACCESS_KEY=

# MiniMax AI translations (dish/menu text -> English).
# Leave MINIMAX_API_KEY empty to disable translations (dishes save Spanish only).
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M3
MINIMAX_TRANSLATE_TIMEOUT_SECONDS=20
MINIMAX_TRANSLATE_CONCURRENCY=4
